{
  "radius": {
    "base": "0.5rem",
    "scale": {
      "none": 0,
      "xs": 2,
      "sm": 6,
      "md": 8,
      "lg": 10,
      "xl": 14,
      "2xl": 18,
      "3xl": 22,
      "4xl": 26,
      "full": 9999
    }
  },
  "fontSize": {
    "2xs": { "size": "10px", "lineHeight": "12px" }
  },
  "zIndex": {
    "base": 0,
    "sticky": 10,
    "overlay": 50,
    "toast": 100
  },
  "motion": {
    "duration": {
      "fast": "100ms",
      "base": "200ms",
      "slow": "300ms"
    },
    "ease": {
      "emphasized": "cubic-bezier(0.22, 1, 0.36, 1)"
    }
  },
  "ring": {
    "width": "3px"
  }
